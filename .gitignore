# =============================================================
# Python / Backend
# =============================================================

# Environment variables — never commit secrets
.env
.env.*
!.env.example

# Virtual environments
venv/
.venv/
env/
.env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/

# LlamaIndex / RAG storage
storage/
*.db
!AdvRag/src/storage/
!AdvRag/src/storage/*.py

# Data directories (add back selectively if you want sample data tracked)
data/docs/
data/tables/

# =============================================================
# React / Vite / Node (Frontend)
# =============================================================

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Vite
*.local
.vite/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================
# Editor & OS
# =============================================================

# VS Code (keep extensions recommendation)
.vscode/*
!.vscode/extensions.json

# JetBrains IDEs
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
